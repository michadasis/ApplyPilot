#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn credentials (for persistent session login)
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your_password_here

# Candidate Personal Info
# Used to fill standard form fields (name, contact, etc.)
CANDIDATE_FIRST_NAME=John
CANDIDATE_LAST_NAME=Doe
CANDIDATE_EMAIL=john.doe@example.com
CANDIDATE_PHONE=+1-555-555-5555
CANDIDATE_LINKEDIN=https://linkedin.com/in/johndoe
CANDIDATE_GITHUB=https://github.com/johndoe
CANDIDATE_PORTFOLIO=https://johndoe.dev
CANDIDATE_CITY=New York
CANDIDATE_STATE=NY

# EEO / Demographic (used for voluntary disclosure fields)
# Set to exact option text you want selected, or "I don't wish to answer"
CANDIDATE_WORK_AUTH=Yes
CANDIDATE_VETERAN_STATUS=I am not a protected veteran
CANDIDATE_DISABILITY=I don't wish to answer
CANDIDATE_ETHNICITY=I don't wish to answer
CANDIDATE_GENDER=I don't wish to answer

# Resume file paths
# Defaults to resume/resume.pdf and resume/resume.md
# RESUME_PDF_PATH=/absolute/path/to/resume.pdf
# RESUME_MD_PATH=/absolute/path/to/resume.md
